classDiagram
    class Owner {
        +String owner_id
        +String name
        +String email
        +String phone
        +List~Pet~ pets
        +Scheduler scheduler
        +add_pet(pet) void
        +remove_pet(pet_id) void
        +get_pets() List~Pet~
        +schedule_task(task, scheduler) void
        +get_all_tasks() List~Task~
        +get_tasks_for_pet(pet_id) List~Task~
    }

    class Pet {
        +String name
        +String species
        +String breed
        +int age
        +float weight
        +String owner_id
        +List~String~ medical_history
        +List~Task~ tasks
        +get_profile() String
        +add_medical_note(note) void
        +get_age() int
        +get_tasks() List~Task~
    }

    class Task {
        +String task_id
        +String type
        +String description
        +String pet_id
        +String owner_id
        +datetime due_date
        +String status
        +Optional~String~ recurrence
        +complete() void
        +is_overdue() bool
        +reschedule(new_date) void
        +get_next_occurrence() Optional~datetime~
    }

    class Scheduler {
        +List~Task~ tasks
        +List~String~ notifications
        +Dict~String_Owner~ owners
        +add_task(task, pet) Optional~String~
        +remove_task(task_id) void
        +get_tasks_for_pet(pet_id) List~Task~
        +get_upcoming_tasks(days) List~Task~
        +get_tasks_by_status(status) List~Task~
        +check_overdue_tasks() List~Task~
        +has_conflict(task, duration_minutes) Optional~String~
        +send_reminder(task, owner) void
    }

    Owner "1" *-- "0..*" Pet : owns
    Pet "1" *-- "0..*" Task : tracks
    Scheduler "1" o-- "0..*" Task : manages
    Scheduler "1" o-- "0..*" Owner : registers
    Owner "1" --> "1" Scheduler : queries
